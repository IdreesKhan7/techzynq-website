# ─── App ────────────────────────────────────────────────────────────────────
SESSION_SECRET=your-super-secret-session-key-change-this
PORT=3000

# ─── Admin account ──────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@techzynq.com
# Generate hash: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2a$12$examplehashhere

# ─── Email / SMTP ───────────────────────────────────────────────────────────
# Option A — Hostinger domain email (recommended if your domain mail is on Hostinger):
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=contact@yourdomain.com
SMTP_PASS=your-mailbox-password
# Option B — Gmail: enable 2-Step Verification, then create an App Password at
# myaccount.google.com/apppasswords and use smtp.gmail.com / port 587.

# Address(es) that receive contact form submissions — comma-separated for multiple.
CONTACT_RECIPIENT=contact@yourdomain.com,business@yourdomain.com
