# ─── App ────────────────────────────────────────────────────────────────────
SESSION_SECRET=your-super-secret-session-key-change-this
PORT=3000

# ─── Admin account ──────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@techzynq.com
# Generate hash: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=$2a$12$examplehashhere

# ─── Email / SMTP ───────────────────────────────────────────────────────────
# For Gmail: turn on 2-Step Verification, then go to
# myaccount.google.com/apppasswords and create a 16-char App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Email address that receives contact form submissions (defaults to SMTP_USER)
CONTACT_RECIPIENT=your-email@example.com
