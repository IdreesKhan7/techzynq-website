<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="max-w-4xl mx-auto px-4 sm:px-6 py-16">
  <div class="mb-10 fade-up">
    <span class="font-mono text-xs text-brand-cyan uppercase tracking-widest block mb-3">Reach out</span>
    <h1 class="font-heading font-bold text-5xl text-brand-text mb-2">Contact</h1>
    <p class="text-brand-muted">We'd love to hear from you — tips, partnerships, press, or general questions.</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">
    <!-- Left: Direct contact emails -->
    <div class="lg:col-span-2 space-y-4 fade-up">
      <h2 class="font-heading font-semibold text-lg text-brand-text mb-4">Direct Contact</h2>

      <div class="bg-brand-card border border-brand-border rounded-xl p-5 hover:border-brand-cyan/30 transition-colors">
        <div class="flex items-start gap-3">
          <div class="w-9 h-9 rounded-lg bg-brand-primary/20 flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-mono text-brand-tertiary uppercase tracking-widest mb-1">General Questions</p>
            <a href="mailto:contact@techzynq.com" class="text-brand-cyan font-medium hover:underline text-sm">contact@techzynq.com</a>
          </div>
        </div>
      </div>

      <div class="bg-brand-card border border-brand-border rounded-xl p-5 hover:border-brand-cyan/30 transition-colors">
        <div class="flex items-start gap-3">
          <div class="w-9 h-9 rounded-lg bg-brand-cyan/10 flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-4 h-4 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-mono text-brand-tertiary uppercase tracking-widest mb-1">Business Enquiries</p>
            <a href="mailto:business@techzynq.com" class="text-brand-cyan font-medium hover:underline text-sm">business@techzynq.com</a>
          </div>
        </div>
      </div>

      <p class="text-xs text-brand-tertiary leading-relaxed pt-2">
        We typically respond within 1–2 business days. For urgent press queries, please indicate it in your subject line.
      </p>
    </div>

    <!-- Right: Contact form -->
    <div class="lg:col-span-3 fade-up">
      <% if (success) { %>
      <!-- Success state -->
      <div class="bg-brand-card border border-brand-cyan/30 rounded-2xl p-8 text-center">
        <div class="w-14 h-14 rounded-full bg-brand-cyan/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h2 class="font-heading font-bold text-2xl text-brand-text mb-2">Message sent!</h2>
        <p class="text-brand-muted mb-6">Thanks for reaching out. We'll get back to you within 1–2 business days.</p>
        <a href="/" class="btn-outline">Back to Home</a>
      </div>
      <% } else { %>
      <div class="bg-brand-card border border-brand-border rounded-2xl p-8 relative overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-px bg-brand-gradient-r opacity-30"></div>

        <% if (errors && errors.length > 0) { %>
        <div class="bg-red-500/10 border border-red-500/30 rounded-lg p-4 mb-6">
          <ul class="space-y-1">
            <% errors.forEach(e => { %>
            <li class="text-red-400 text-sm">• <%= e %></li>
            <% }) %>
          </ul>
        </div>
        <% } %>

        <form method="POST" action="/contact" class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="form-label">Name *</label>
              <input type="text" name="name" required
                     value="<%= typeof form !== 'undefined' && form ? form.name || '' : '' %>"
                     placeholder="Your name" class="form-input" />
            </div>
            <div>
              <label class="form-label">Email *</label>
              <input type="email" name="email" required
                     value="<%= typeof form !== 'undefined' && form ? form.email || '' : '' %>"
                     placeholder="your@email.com" class="form-input" />
            </div>
          </div>

          <div>
            <label class="form-label">Reason</label>
            <select name="reason" class="form-input">
              <% const reasons = ['General Question', 'Business Enquiry', 'Press & Media', 'Tip']; %>
              <% reasons.forEach(r => { %>
              <option value="<%= r %>" <%= (typeof form !== 'undefined' && form && form.reason === r) ? 'selected' : '' %>><%= r %></option>
              <% }) %>
            </select>
          </div>

          <div>
            <label class="form-label">Message *</label>
            <textarea name="message" rows="6" required
                      placeholder="Tell us what's on your mind…"
                      class="form-input resize-none"><%= typeof form !== 'undefined' && form ? form.message || '' : '' %></textarea>
          </div>

          <button type="submit" class="btn-primary w-full justify-center">
            Send Message
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </button>
        </form>
      </div>
      <% } %>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
</body>
</html>
