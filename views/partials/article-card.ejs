<%
/* Expects: article object, optional: size ('sm'|'md'|'lg'), showExcerpt */
const cardSize   = typeof size !== 'undefined' ? size : 'md';
const showExcerpt = typeof showExc !== 'undefined' ? showExc : (cardSize !== 'sm');
const imgPath    = article.coverImage
                   ? (/\.(svg|png|jpg|jpeg|webp|gif)$/i.test(article.coverImage)
                       ? article.coverImage
                       : article.coverImage + '-md.webp')
                   : (article.category === 'AI' ? '/images/placeholder-ai.svg' : '/images/placeholder-tech.svg');
const pubDate    = article.publishedAt ? new Date(article.publishedAt).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}) : '';
%>
<a href="/article/<%= article.slug %>" class="card group flex flex-col h-full hover:shadow-glow-cyan hover:-translate-y-0.5 transition-all duration-300">
  <!-- Cover image -->
  <div class="relative overflow-hidden <%= cardSize === 'sm' ? 'h-36' : 'h-48' %> flex-shrink-0">
    <img src="<%= imgPath %>" alt="<%= article.title %>"
         loading="lazy"
         class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
    <div class="absolute inset-0 bg-gradient-to-t from-brand-card/80 to-transparent"></div>
    <!-- Category badge -->
    <div class="absolute top-3 left-3">
      <span class="<%= article.category === 'AI' ? 'badge-ai' : 'badge-tech' %>">
        <%= article.category %>
      </span>
    </div>
    <% if (article.isBreaking) { %>
    <div class="absolute top-3 right-3 flex items-center gap-1 bg-brand-primary/90 rounded px-2 py-0.5">
      <span class="w-1.5 h-1.5 rounded-full bg-brand-cyan live-dot"></span>
      <span class="font-mono text-xs text-white font-medium">LIVE</span>
    </div>
    <% } %>
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1 p-4">
    <h3 class="font-heading font-semibold text-brand-text text-balance leading-snug mb-2
               <%= cardSize === 'sm' ? 'text-sm' : 'text-base' %>
               group-hover:text-brand-cyan transition-colors duration-200">
      <%= article.title %>
    </h3>
    <% if (showExcerpt && article.excerpt) { %>
    <p class="text-brand-muted text-xs leading-relaxed mb-3 line-clamp-2 flex-1"><%= article.excerpt %></p>
    <% } %>
    <!-- Meta -->
    <div class="flex items-center gap-2 mt-auto pt-2 border-t border-brand-border/50">
      <span class="font-mono text-xs text-brand-tertiary"><%= pubDate %></span>
      <span class="text-brand-tertiary">·</span>
      <span class="font-mono text-xs text-brand-tertiary"><%= article.readTimeMinutes %> MIN READ</span>
    </div>
  </div>
</a>
