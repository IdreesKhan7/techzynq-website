<%- include('partials/head') %>
<%- include('partials/header') %>

<main class="max-w-4xl mx-auto px-4 sm:px-6 py-16">
  <!-- Page header -->
  <div class="mb-12 fade-up">
    <span class="font-mono text-xs text-brand-cyan uppercase tracking-widest block mb-3">Our story</span>
    <h1 class="font-heading font-bold text-5xl text-brand-text mb-4">About TechZynq</h1>
    <div class="h-1 w-20 bg-brand-gradient-r rounded-full"></div>
  </div>

  <!-- Mission section -->
  <section class="mb-14 fade-up">
    <div class="bg-brand-card border border-brand-border rounded-2xl p-8 relative overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-px bg-brand-gradient-r opacity-30"></div>
      <h2 class="font-heading font-bold text-2xl text-brand-text mb-4">Our Mission</h2>
      <p class="text-brand-muted text-lg leading-relaxed mb-4">
        TechZynq exists because the technology beat — particularly artificial intelligence — has never been more consequential, and never more crowded with noise.
      </p>
      <p class="text-brand-muted leading-relaxed mb-4">
        We cover AI and technology with precision: no hype cycles, no breathless speculation, no thinly disguised press releases. Every article we publish is written by a human who understands the technology, has read the source, and can explain the implications clearly.
      </p>
      <p class="text-brand-muted leading-relaxed">
        Our audience is builders, operators, investors, and curious minds who want to stay genuinely informed — not just in the loop. We write for people who can tell the difference.
      </p>
    </div>
  </section>

  <!-- What we cover -->
  <section class="mb-14 fade-up">
    <h2 class="font-heading font-bold text-2xl text-brand-text mb-6">What We Cover</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="bg-brand-card border border-brand-border rounded-xl p-5 hover:border-brand-cyan/30 transition-colors">
        <div class="w-8 h-8 rounded-lg bg-brand-primary/20 flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H4a2 2 0 01-2-2V5a2 2 0 012-2h16a2 2 0 012 2v10a2 2 0 01-2 2h-1"/></svg>
        </div>
        <h3 class="font-heading font-semibold text-brand-text mb-1">Artificial Intelligence</h3>
        <p class="text-brand-muted text-sm">Foundation models, agentic systems, research breakthroughs, regulation, and the business of AI.</p>
      </div>
      <div class="bg-brand-card border border-brand-border rounded-xl p-5 hover:border-brand-cyan/30 transition-colors">
        <div class="w-8 h-8 rounded-lg bg-brand-cyan/10 flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
        </div>
        <h3 class="font-heading font-semibold text-brand-text mb-1">Hardware & Chips</h3>
        <p class="text-brand-muted text-sm">GPUs, ASICs, mobile silicon, and the infrastructure powering the AI revolution.</p>
      </div>
      <div class="bg-brand-card border border-brand-border rounded-xl p-5 hover:border-brand-cyan/30 transition-colors">
        <div class="w-8 h-8 rounded-lg bg-brand-primary/20 flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        </div>
        <h3 class="font-heading font-semibold text-brand-text mb-1">Startups & Funding</h3>
        <p class="text-brand-muted text-sm">The companies, founders, and capital flows shaping the next decade of technology.</p>
      </div>
      <div class="bg-brand-card border border-brand-border rounded-xl p-5 hover:border-brand-cyan/30 transition-colors">
        <div class="w-8 h-8 rounded-lg bg-brand-cyan/10 flex items-center justify-center mb-3">
          <svg class="w-4 h-4 text-brand-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/></svg>
        </div>
        <h3 class="font-heading font-semibold text-brand-text mb-1">Global Tech</h3>
        <p class="text-brand-muted text-sm">Technology adoption and innovation in emerging markets, with a focus on Africa and the Middle East.</p>
      </div>
    </div>
  </section>

  <!-- Founder note -->
  <section class="mb-14 fade-up">
    <h2 class="font-heading font-bold text-2xl text-brand-text mb-6">From the Founder</h2>
    <div class="bg-brand-card border border-brand-border rounded-2xl p-8">
      <blockquote class="text-brand-muted text-lg leading-relaxed italic mb-6 border-l-4 border-brand-cyan pl-5">
        "I started TechZynq because I couldn't find a technology publication that wrote for people who actually build things. Too much of tech journalism is either academic to the point of inaccessibility, or simplistic to the point of uselessness. TechZynq is the middle path: rigorous, readable, and relevant."
      </blockquote>
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-brand-elevated border border-brand-border flex items-center justify-center">
          <span class="font-mono text-sm text-brand-cyan font-bold">IK</span>
        </div>
        <div>
          <p class="font-heading font-semibold text-brand-text">Idrees Khan</p>
          <p class="text-brand-muted text-sm">Founder & Editor-in-Chief, TechZynq</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="fade-up">
    <div class="bg-brand-gradient rounded-2xl p-8 text-center relative overflow-hidden">
      <div class="absolute inset-0 circuit-bg opacity-20"></div>
      <div class="relative z-10">
        <h2 class="font-heading font-bold text-2xl text-white mb-2">Get in Touch</h2>
        <p class="text-white/80 mb-6">Tips, press enquiries, business partnerships — we'd love to hear from you.</p>
        <a href="/contact" class="inline-flex items-center gap-2 bg-white text-brand-primary font-semibold px-6 py-3 rounded-lg hover:bg-brand-text transition-colors">
          Contact Us →
        </a>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
<%- include('partials/scripts') %>
</body>
</html>
