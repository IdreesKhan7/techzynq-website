<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="min-h-screen bg-brand-bg text-brand-text font-body flex">
  <!-- Sidebar -->
  <aside class="w-56 min-h-screen bg-brand-card border-r border-brand-border flex flex-col fixed top-0 left-0 z-30">
    <!-- Logo -->
    <div class="px-5 py-5 border-b border-brand-border">
      <a href="/" class="block">
        <img src="/images/logo-h.png" alt="TechZynq" class="h-7 w-auto" style="mix-blend-mode:screen;" />
      </a>
      <p class="text-xs text-brand-tertiary mt-1 font-mono">Admin</p>
    </div>

    <!-- Nav -->
    <nav class="flex-1 px-3 py-4 space-y-1">
      <a href="/admin"           class="admin-sidebar-link <%= typeof currentAdminPath !== 'undefined' && currentAdminPath === '/admin' ? 'active' : '' %>">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Dashboard
      </a>
      <a href="/admin/articles"  class="admin-sidebar-link <%= typeof currentAdminPath !== 'undefined' && currentAdminPath === '/admin/articles' ? 'active' : '' %>">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10l6 6v10a2 2 0 01-2 2z"/><path d="M14 4v6h6M8 13h8M8 17h5"/></svg>
        Articles
      </a>
      <a href="/admin/articles/new" class="admin-sidebar-link">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 4v16m8-8H4"/></svg>
        New Article
      </a>
      <a href="/admin/messages"  class="admin-sidebar-link <%= typeof currentAdminPath !== 'undefined' && currentAdminPath === '/admin/messages' ? 'active' : '' %>">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        Messages
        <% if (typeof unreadMessages !== 'undefined' && unreadMessages > 0) { %>
        <span class="ml-auto bg-brand-primary text-white text-xs rounded-full px-1.5 py-0.5"><%= unreadMessages %></span>
        <% } %>
      </a>
    </nav>

    <!-- Bottom -->
    <div class="px-3 py-4 border-t border-brand-border">
      <a href="/" class="admin-sidebar-link text-xs">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        View site
      </a>
      <a href="/admin/logout" class="admin-sidebar-link text-xs text-red-400 hover:text-red-300 mt-1">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        Logout
      </a>
    </div>
  </aside>

  <!-- Main content -->
  <div class="flex-1 ml-56 min-h-screen">
