<%- include('partials/head') %>

<!-- Reading progress bar -->
<div id="reading-progress"></div>

<%- include('partials/header') %>

<main>
  <%
  const imgSrc = article.coverImage
    ? (/\.(svg|png|jpg|jpeg|webp|gif)$/i.test(article.coverImage)
        ? article.coverImage
        : article.coverImage + '-lg.webp')
    : (article.category === 'AI' ? '/images/placeholder-ai.svg' : '/images/placeholder-tech.svg');
  const pubDate = article.publishedAt
    ? new Date(article.publishedAt).toLocaleDateString('en-GB',{day:'numeric',month:'long',year:'numeric'})
    : '';
  %>

  <!-- Hero image -->
  <div class="relative h-72 md:h-[480px] overflow-hidden">
    <img src="<%= imgSrc %>" alt="<%= article.title %>" width="1280" height="800" fetchpriority="high" class="w-full h-full object-cover" />
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent 30%, #05070D 100%)"></div>
    <% if (article.coverCredit) { %>
    <p class="absolute bottom-2 right-3 text-[10px] text-brand-tertiary/70 font-mono z-10"><%= article.coverCredit %></p>
    <% } %>
  </div>

  <!-- Article container -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 -mt-16 relative z-10">
    <!-- Header -->
    <div class="mb-8">
      <!-- Kicker row -->
      <div class="flex items-center gap-3 mb-4">
        <a href="/<%= article.category.toLowerCase() %>" class="<%= article.category === 'AI' ? 'badge-ai' : 'badge-tech' %>">
          <%= article.category %>
        </a>
        <% if (article.isBreaking) { %>
        <span class="flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-brand-cyan live-dot"></span>
          <span class="font-mono text-xs text-brand-cyan uppercase tracking-widest">Breaking</span>
        </span>
        <% } %>
      </div>

      <!-- Headline -->
      <h1 class="font-heading font-bold text-3xl sm:text-4xl md:text-5xl text-brand-text leading-tight mb-4 text-balance">
        <%= article.title %>
      </h1>

      <!-- Excerpt -->
      <p class="text-brand-muted text-lg leading-relaxed mb-6 border-l-2 border-brand-cyan pl-4">
        <%= article.excerpt %>
      </p>

      <!-- Meta row -->
      <div class="flex flex-wrap items-center gap-4 pb-6 border-b border-brand-border">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-brand-elevated border border-brand-border flex items-center justify-center">
            <span class="font-mono text-xs text-brand-cyan"><%= article.author.name.charAt(0) %></span>
          </div>
          <span class="text-sm text-brand-muted font-medium"><%= article.author.name %></span>
        </div>
        <span class="text-brand-tertiary">·</span>
        <span class="font-mono text-sm text-brand-muted"><%= pubDate %></span>
        <span class="text-brand-tertiary">·</span>
        <span class="font-mono text-sm text-brand-muted"><%= article.readTimeMinutes %> MIN READ</span>
        <span class="text-brand-tertiary">·</span>
        <span class="font-mono text-sm text-brand-tertiary"><%= article.views %> views</span>
      </div>

      <!-- Tags -->
      <% if (article.tags && article.tags.length > 0) { %>
      <div class="flex flex-wrap gap-2 mt-4">
        <% article.tags.forEach(t => { %>
        <a href="/tag/<%= t %>" class="tag">#<%= t %></a>
        <% }) %>
      </div>
      <% } %>
    </div>

    <!-- Article body -->
    <div class="article-body text-brand-text leading-loose text-base sm:text-lg mb-10">
      <%- article.body %>
    </div>

    <!-- Share buttons -->
    <div class="border-t border-b border-brand-border py-6 mb-10">
      <p class="text-xs font-mono text-brand-tertiary uppercase tracking-widest mb-3">Share this story</p>
      <div class="flex flex-wrap gap-3">
        <button onclick="copyLink()" class="share-btn">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          <span id="copy-label">Copy link</span>
        </button>
        <a href="https://twitter.com/intent/tweet?text=<%= encodeURIComponent(article.title) %>&url=<%= encodeURIComponent('https://techzynq.com/article/' + article.slug) %>"
           target="_blank" rel="noopener" class="share-btn">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          X / Twitter
        </a>
        <a href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodeURIComponent('https://techzynq.com/article/' + article.slug) %>"
           target="_blank" rel="noopener" class="share-btn">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a href="https://api.whatsapp.com/send?text=<%= encodeURIComponent(article.title + ' — https://techzynq.com/article/' + article.slug) %>"
           target="_blank" rel="noopener" class="share-btn">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>

    <!-- Newsletter CTA -->
    <div class="bg-brand-card border border-brand-border rounded-2xl p-6 mb-12 relative overflow-hidden">
      <div class="absolute top-0 left-0 right-0 h-px bg-brand-gradient-r opacity-40"></div>
      <h3 class="font-heading font-bold text-xl text-brand-text mb-2">Enjoyed this article?</h3>
      <p class="text-brand-muted text-sm mb-4">Get the weekly TechZynq digest — the most important AI & Tech stories, distilled.</p>
      <form class="article-newsletter flex flex-col sm:flex-row gap-3">
        <input type="email" name="email" placeholder="your@email.com" required class="newsletter-input flex-1" />
        <button type="submit" class="btn-primary flex-shrink-0">Subscribe</button>
      </form>
      <p class="article-newsletter-msg text-sm text-brand-cyan mt-2 hidden"></p>
    </div>
  </div>

  <!-- Related articles -->
  <% if (related && related.length > 0) { %>
  <section class="border-t border-brand-border py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <h2 class="font-heading font-bold text-2xl text-brand-text mb-8">Related Stories</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <% related.forEach((a) => { %>
        <% let size = 'md'; let showExc = true; %>
        <%- include('partials/article-card', { article: a, size, showExc }) %>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>
</main>

<%- include('partials/footer') %>

<script>
function copyLink() {
  navigator.clipboard.writeText(window.location.href).then(() => {
    const label = document.getElementById('copy-label');
    label.textContent = 'Copied!';
    setTimeout(() => label.textContent = 'Copy link', 2000);
  });
}

// Reading progress
const bar = document.getElementById('reading-progress');
if (bar) {
  window.addEventListener('scroll', () => {
    const docH   = document.documentElement.scrollHeight - window.innerHeight;
    const pct    = docH > 0 ? (window.scrollY / docH) * 100 : 0;
    bar.style.width = pct + '%';
  });
}

// Article newsletter
document.querySelector('.article-newsletter')?.addEventListener('submit', async e => {
  e.preventDefault();
  const email = e.target.querySelector('[name=email]').value;
  const msg   = e.target.nextElementSibling;
  const r     = await fetch('/subscribe', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ email }) });
  const data  = await r.json();
  msg.textContent = data.message;
  msg.classList.remove('hidden');
  if (data.ok) e.target.reset();
});
</script>

<%- include('partials/scripts') %>
</body>
</html>
